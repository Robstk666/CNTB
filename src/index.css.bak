@tailwind base;
@tailwind components;
@tailwind utilities;

@layer base {
  body {
    @apply font-ans bg-[#f5f5f7] text-[#1d1d1f] antialiased selection:bg-[#0071e3] selection:text-white;
  }
}

@layer utilities {
  .apple-card {
    @apply bg-white/70 backdrop-blur-2xl rounded-[24px] shadow-[0_8px_30px_rgb(0,0,0,0.04)] border border-white/80 transition-all duration-300 ease-out;
  }

  .apple-card:hover {
    @apply shadow-[0_20px_40px_rgb(0,0,0,0.08)] -translate-y-1 bg-white/90 border-white;
  }

  .apple-button-primary {
    @apply bg-[#0071e3] text-white rounded-full font-medium px-6 py-3 shadow-[0_4px_14px_rgba(0,113,227,0.39)] hover:bg-[#0077ED] hover:shadow-[0_6px_20px_rgba(0,113,227,0.23)] active:scale-95 transition-all duration-200 flex items-center justify-center;
  }

  .apple-button-secondary {
    @apply bg-white/80 backdrop-blur-md text-[#1d1d1f] rounded-full font-medium px-6 py-3 shadow-[0_2px_10px_rgba(0,0,0,0.04)] border border-gray-200/50 hover:bg-white hover:shadow-[0_4px_15px_rgba(0, 0, 0, 0.08)] active:scale-95 transition-all duration-200 flex items-center justify-center;
  }

  .apple-glass-header {
    @apply bg-white/70 backdrop-blur-xl border-b border-gray-200/50 sticky top-0 z-50;
  }

  .apple-glass-footer {
    @apply bg-white/70 backdrop-blur-xl border-t border-gray-200/50 sticky bottom-0 z-50;
  }
}